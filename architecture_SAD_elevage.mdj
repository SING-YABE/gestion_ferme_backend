{
  "_type": "Project",
  "_id": "PROJECT_SAD_2026",
  "name": "SAD Élevage Porcin — Architecture Système 2026",
  "ownedElements": [
    {
      "_type": "UMLModel",
      "_id": "MODEL_GLOBAL",
      "name": "Architecture Technique Complète",
      "documentation": "Projet Mémoire Master 2026 — Burkina Faso\nPlateforme IA Élevage Porcin de Précision\nAnalyse basée sur code source réel",
      "ownedElements": [
        {
          "_type": "UMLComponentDiagram",
          "_id": "DF1026E736514161A1E6",
          "name": "01 — Architecture Globale",
          "documentation": "Vue d'ensemble du système SAD Élevage Porcin Burkina Faso\nCe diagramme montre les 4 composants applicatifs principaux,\nles 2 bases de données, et les services externes.",
          "ownedElements": []
        },
        {
          "_type": "UMLClassDiagram",
          "_id": "8A54E7B234EC4C76AA62",
          "name": "02 — Modèle de Données Spring Boot (JPA)",
          "documentation": "Entités JPA Hibernate — Base PostgreSQL snackboost_db\nRelations identifiées à partir du code source Kotlin",
          "ownedElements": []
        },
        {
          "_type": "UMLSequenceDiagram",
          "_id": "8C9A96697FC84C928997",
          "name": "03 — Flux Authentification JWT",
          "documentation": "POST /login → Spring Boot → BCrypt verify → JWT token\nToken stocké: Flutter (SecureStorage), Angular (localStorage)",
          "ownedElements": []
        },
        {
          "_type": "UMLSequenceDiagram",
          "_id": "26DB55A047084B39AD9A",
          "name": "04 — Flux Extraction Prix WhatsApp",
          "documentation": "WhatsApp → Webhook Python → Gemini 2.5 Flash → Extract prix\n→ Whisper (audio) → PostgreSQL prix_aliments\n→ Entraînement XGBoost → Prédictions mobiles/web",
          "ownedElements": []
        },
        {
          "_type": "UMLComponentDiagram",
          "_id": "EDB2681D41804E0B82E8",
          "name": "05 — Backend Python FastAPI (Détail)",
          "documentation": "Architecture interne du backend Python\nRouters, Services, ML Pipeline, External APIs",
          "ownedElements": []
        },
        {
          "_type": "UMLComponentDiagram",
          "_id": "F63F778AE7B04DEA99DD",
          "name": "06 — Mobile Flutter (Architecture par couche)",
          "documentation": "Architecture Flutter — Provider Pattern\nCouches: Presentation → Provider → Repository → Service HTTP",
          "ownedElements": []
        },
        {
